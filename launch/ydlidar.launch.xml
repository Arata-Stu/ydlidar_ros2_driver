<launch>
  <arg name="ydlidar_config" default="$(find-pkg-share ydlidar_ros2_driver)/config/t_mini_plus.param.yaml"/>

  <node name="ydlidar_ros2_driver_node" pkg="ydlidar_ros2_driver" exec="ydlidar_ros2_driver_node" output="screen" respawn="false">
    <param from="$(var ydlidar_config)"/>
  </node>
</launch>
